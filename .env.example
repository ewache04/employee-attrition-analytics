# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Kaggle Auto-Download (Method B) ──────────────────────────────────────────
# Only needed if you have NOT placed kaggle.json in ~/.kaggle/kaggle.json
# Get your key: https://www.kaggle.com/settings → API → Create New Token
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_api_key

# ── Optional path override ────────────────────────────────────────────────────
# DATA_SOURCE_PATH=C:/Downloads/WA_Fn-UseC_-HR-Employee-Attrition.csv